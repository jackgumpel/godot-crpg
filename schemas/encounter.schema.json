{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godot-crpg.local/schemas/encounter.schema.json",
  "title": "encounter_set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "dataset_type",
    "encounter_set_id",
    "entry_node_id",
    "nodes"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "dataset_type": {
      "const": "encounter_set"
    },
    "encounter_set_id": {
      "$ref": "#/$defs/id"
    },
    "entry_node_id": {
      "$ref": "#/$defs/id"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_id",
        "page_start",
        "page_end"
      ],
      "properties": {
        "document_id": {
          "$ref": "#/$defs/id"
        },
        "page_start": {
          "type": "integer",
          "minimum": 1
        },
        "page_end": {
          "type": "integer",
          "minimum": 1
        },
        "section_title": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "import_notes": {
          "type": "string"
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "next"
      ],
      "properties": {
        "next": {
          "$ref": "#/$defs/id"
        },
        "journal_add": {
          "type": "string"
        },
        "set_flags": {
          "type": "object",
          "additionalProperties": {
            "type": "boolean"
          }
        },
        "add_counters": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        },
        "set_quest_states": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
          }
        },
        "end_encounter": {
          "type": "boolean"
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "skill",
        "difficulty",
        "on_success",
        "on_failure"
      ],
      "properties": {
        "skill": {
          "$ref": "#/$defs/id"
        },
        "difficulty": {
          "type": "integer",
          "minimum": 0
        },
        "hint_text": {
          "type": "string"
        },
        "on_success": {
          "$ref": "#/$defs/result"
        },
        "on_failure": {
          "$ref": "#/$defs/result"
        }
      }
    },
    "choice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "text"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "$ref": "#/$defs/result"
        },
        "check": {
          "$ref": "#/$defs/check"
        },
        "ui_tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      },
      "oneOf": [
        {
          "required": [
            "result"
          ]
        },
        {
          "required": [
            "check"
          ]
        }
      ]
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "body",
        "choices"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string",
          "minLength": 1
        },
        "choices": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/choice"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_ref"
          }
        }
      }
    }
  }
}
