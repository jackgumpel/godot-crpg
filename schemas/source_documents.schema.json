{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godot-crpg.local/schemas/source_documents.schema.json",
  "title": "source_documents",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "dataset_type",
    "documents"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "dataset_type": {
      "const": "source_documents"
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "source_pdf",
          "ocr_status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "source_pdf": {
            "type": "string",
            "minLength": 1
          },
          "ocr_status": {
            "type": "string",
            "enum": [
              "pending_ocr",
              "ocr_complete"
            ]
          },
          "ocr_content_path": {
            "type": "string"
          },
          "ocr_plain_text_path": {
            "type": "string"
          },
          "ocr_manifest_path": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
