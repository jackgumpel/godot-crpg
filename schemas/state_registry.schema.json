{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godot-crpg.local/schemas/state_registry.schema.json",
  "title": "state_registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "dataset_type",
    "flags",
    "counters",
    "quest_states"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "dataset_type": {
      "const": "state_registry"
    },
    "flags": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/flag"
      }
    },
    "counters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/counter"
      }
    },
    "quest_states": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/quest_state"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "flag": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "default",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "default": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "counter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "default",
        "min",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "default": {
          "type": "integer"
        },
        "min": {
          "type": "integer"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "quest_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "allowed_values",
        "default",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "allowed_values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
          }
        },
        "default": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
