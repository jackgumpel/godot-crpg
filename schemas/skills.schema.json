{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godot-crpg.local/schemas/skills.schema.json",
  "title": "skills_registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "dataset_type",
    "skills"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "dataset_type": {
      "const": "skills_registry"
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "description",
          "kind"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "knowledge",
              "social",
              "physical",
              "survival",
              "magic",
              "will"
            ]
          }
        }
      }
    }
  }
}
